<%
const emitente = document.emitente || {};
const customSectionsList = customSections || [];
const extraInfo = additionalInfo || {};
const rows = Object.entries(extraInfo);
const eventTitle = document.kind === 'cancelamento'
  ? 'Representacao Grafica de Evento de Cancelamento de CT-e'
  : 'Representacao Grafica de Carta de Correcao Eletronica de CT-e';
%>
<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <title><%= eventTitle %></title>
  <style>
    * {
      box-sizing: border-box;
      -webkit-print-color-adjust: exact !important;
      print-color-adjust: exact !important;
    }

    @page {
      size: A4 portrait;
      margin: 7mm;
    }

    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      color: #111;
      font-size: 9px;
    }

    .page {
      width: 196mm;
      margin: 0 auto;
    }

    .box {
      border: 1px solid #000;
      margin-bottom: 2mm;
    }

    .box-body {
      padding: 2.5mm;
    }

    .title {
      padding: 2.5mm;
      border-bottom: 1px solid #000;
      background: #efefef;
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      text-align: center;
    }

    .subtitle {
      font-size: 8px;
      text-align: center;
      line-height: 1.35;
    }

    .grid-2, .grid-3 {
      display: grid;
      gap: 0;
    }

    .grid-2 { grid-template-columns: 1fr 1fr; }
    .grid-3 { grid-template-columns: 1fr 1fr 1fr; }

    .cell {
      border-right: 1px solid #000;
      border-bottom: 1px solid #000;
      padding: 2.5mm;
      min-height: 14mm;
    }

    .grid-2 .cell:nth-child(2n),
    .grid-3 .cell:nth-child(3n) {
      border-right: none;
    }

    .label {
      font-size: 7px;
      font-weight: 700;
      text-transform: uppercase;
      margin-bottom: 1mm;
    }

    .value {
      font-size: 9px;
      line-height: 1.35;
      word-break: break-word;
    }

    .center { text-align: center; }
    .right { text-align: right; }
    .mono { font-family: "Courier New", monospace; }

    table {
      width: 100%;
      border-collapse: collapse;
    }

    th, td {
      border: 1px solid #000;
      padding: 2.5mm;
      vertical-align: top;
    }

    th {
      background: #efefef;
      font-size: 7px;
      text-transform: uppercase;
      text-align: left;
    }

    td {
      font-size: 8.5px;
    }

    .barcode {
      width: 100%;
      height: 18mm;
      object-fit: contain;
    }

    .note {
      padding: 2mm 2.5mm;
      border-top: 1px solid #000;
      font-size: 8px;
      line-height: 1.35;
    }

    .watermark {
      position: fixed;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 42px;
      color: rgba(0, 0, 0, 0.06);
      transform: rotate(-28deg);
      z-index: -1;
      font-weight: 700;
      text-transform: uppercase;
    }
  </style>
</head>
<body>
<% if (watermarkText) { %><div class="watermark"><%= watermarkText %></div><% } %>
<div class="page">
  <div class="box">
    <div class="title"><%= eventTitle %></div>
    <div class="box-body">
      <div class="subtitle">
        Documento auxiliar para conferência interna do evento registrado na SEFAZ vinculado ao CT-e.
      </div>
      <% if (headerNote) { %>
        <div class="note"><%= headerNote %></div>
      <% } %>
    </div>
  </div>

  <div class="box">
    <div class="title">Identificacao do Evento</div>
    <div class="grid-3">
      <div class="cell">
        <div class="label">Evento</div>
        <div class="value"><%= document.descricaoEvento %></div>
      </div>
      <div class="cell">
        <div class="label">Tipo / Sequencia</div>
        <div class="value"><%= document.tipoEvento %> / <%= document.sequenciaEvento %></div>
      </div>
      <div class="cell">
        <div class="label">Modelo</div>
        <div class="value"><%= document.modelo %></div>
      </div>
      <div class="cell">
        <div class="label">Data do Evento</div>
        <div class="value"><%= document.dataEvento || '-' %></div>
      </div>
      <div class="cell">
        <div class="label">Registro na SEFAZ</div>
        <div class="value"><%= document.dataRegistro || '-' %></div>
      </div>
      <div class="cell">
        <div class="label">Ambiente</div>
        <div class="value"><%= document.ambiente || '-' %></div>
      </div>
    </div>
  </div>

  <div class="box">
    <div class="title">CT-e Referenciado</div>
    <div class="box-body">
      <div class="label center">Chave de Acesso</div>
      <div class="value center mono" style="font-size: 12px;"><%= chaveFormatada %></div>
      <div style="margin-top: 2mm;">
        <img class="barcode" src="<%= barcodeDataUrl %>">
      </div>
    </div>
  </div>

  <div class="box">
    <div class="title">Autorizacao do Evento</div>
    <div class="grid-2">
      <div class="cell">
        <div class="label">Protocolo do Evento</div>
        <div class="value"><%= document.protocoloEvento || '-' %></div>
      </div>
      <div class="cell">
        <div class="label">Status / Motivo</div>
        <div class="value"><%= document.statusEvento || '-' %> <%= document.motivo ? `- ${document.motivo}` : '' %></div>
      </div>
      <div class="cell">
        <div class="label">Protocolo de Autorizacao do CT-e</div>
        <div class="value"><%= document.protocoloAutorizacao || '-' %></div>
      </div>
      <div class="cell">
        <div class="label">Documento do Emitente</div>
        <div class="value"><%= emitente.cpfCnpj || '-' %></div>
      </div>
    </div>
  </div>

  <% if (document.kind === 'cancelamento') { %>
    <div class="box">
      <div class="title">Justificativa do Cancelamento</div>
      <div class="box-body">
        <div class="value"><%= document.justificativa || '-' %></div>
      </div>
    </div>
  <% } %>

  <% if (document.kind === 'cce') { %>
    <div class="box">
      <div class="title">Correcao Registrada</div>
      <div class="box-body">
        <div class="value"><%= document.correcaoTexto || '-' %></div>
      </div>
    </div>

    <div class="box">
      <div class="title">Condicoes de Uso</div>
      <div class="box-body">
        <div class="value"><%= document.condicoesUso || '-' %></div>
      </div>
    </div>
  <% } %>

  <% if (rows.length) { %>
    <div class="box">
      <div class="title">Informacoes Complementares</div>
      <table>
        <thead>
          <tr>
            <th style="width: 45mm;">Campo</th>
            <th>Valor</th>
          </tr>
        </thead>
        <tbody>
        <% rows.forEach(([label, value]) => { %>
          <tr>
            <td><%= label %></td>
            <td><%= value %></td>
          </tr>
        <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>

  <% customSectionsList.forEach((section) => { %>
    <div class="box">
      <div class="title"><%= section.title %></div>
      <div class="box-body">
        <% if (section.text) { %>
          <div class="value" style="margin-bottom: 2mm;"><%= section.text %></div>
        <% } %>
        <% if (section.fields && section.fields.length) { %>
          <table>
            <thead>
              <tr>
                <th style="width: 45mm;">Campo</th>
                <th>Valor</th>
              </tr>
            </thead>
            <tbody>
            <% section.fields.forEach((field) => { %>
              <tr>
                <td><%= field.label %></td>
                <td><%= field.value %></td>
              </tr>
            <% }) %>
            </tbody>
          </table>
        <% } %>
      </div>
    </div>
  <% }) %>

  <% if (footerNote) { %>
    <div class="box">
      <div class="title">Observacao Final</div>
      <div class="box-body">
        <div class="value"><%= footerNote %></div>
      </div>
    </div>
  <% } %>
</div>
</body>
</html>
