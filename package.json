{
  "name": "cte-dacte-pdf",
  "version": "1.0.0",
  "description": "Modulo Node.js para gerar PDF DACTE a partir do XML do CT-e.",
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/src/index.js",
  "types": "./dist/types/src/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "docs"
  ],
  "bin": {
    "cte-pdf": "./dist/bin/cte-pdf.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/types/src/index.d.ts",
      "import": "./dist/esm/src/index.js",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/esm/src/index.js"
    }
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "npm run build && node --test test/parser-and-cli.test.mjs"
  },
  "keywords": [
    "cte",
    "dacte",
    "sefaz",
    "pdf",
    "xml"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@xmldom/xmldom": "^0.8.10",
    "bwip-js": "^4.5.1",
    "ejs": "^3.1.10",
    "fast-xml-parser": "^4.5.0",
    "puppeteer": "^24.10.2",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/node": "^22.15.18",
    "@types/qrcode": "^1.5.5",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
